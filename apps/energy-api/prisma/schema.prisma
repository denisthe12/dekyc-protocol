generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnergyUserRole {
  USER
  ADMIN
  JUDGE
  ISSUER
}

enum EnergyWalletStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum EnergyAssetStatus {
  DRAFT
  ACTIVE_SALE
  SOLD_OUT
  PAUSED
  CLOSED
}

enum EnergyPositionStatus {
  ACTIVE
  CLOSED
}

enum EnergyRevenueEpochStatus {
  OPEN
  CLOSED
}

enum EnergyOtcListingStatus {
  OPEN
  FILLED
  CANCELLED
}

enum EnergyPositionPayoutMode {
  KZTE
  ENERGY_POINTS
}

enum EnergyAssetDocumentType {
  PHOTO
  TECH_PASSPORT
  INSTALLER_CERTIFICATE
  MONTHLY_REPORT
  GEO_PROOF
  OTHER
}

model EnergyUser {
  id                String              @id @default(cuid())
  dekycUserId       String              @unique
  email             String?             @db.VarChar(255)
  fullName          String?             @db.VarChar(255)
  role              EnergyUserRole      @default(USER)
  lastLoginAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  profile           EnergyUserProfile?
  wallet            EnergyUserWallet?
  sessions          EnergyUserSession[]
}

model EnergyUserProfile {
  id                String      @id @default(cuid())
  energyUserId      String      @unique
  dekycUserId       String      @db.VarChar(191)
  email             String?     @db.VarChar(255)
  fullName          String?     @db.VarChar(255)
  iin               String?     @db.VarChar(32)
  birthDate         String?     @db.VarChar(64)
  verified          Boolean     @default(false)
  age18Plus         Boolean     @default(false)
  rawClaimsJson     Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              EnergyUser  @relation(fields: [energyUserId], references: [id], onDelete: Cascade)

  @@index([dekycUserId])
}

model EnergyUserWallet {
  id                         String             @id @default(cuid())
  energyUserId               String             @unique
  custodialWalletAddress     String             @unique @db.VarChar(128)
  custodialWalletSecretJson  Json?
  kzteTokenAccountAddress    String?            @unique @db.VarChar(128)
  energyPointsTokenAccountAddress String? @db.VarChar(128)
  energyPointsAccountAddress String?            @unique @db.VarChar(128)
  walletStatus               EnergyWalletStatus @default(PENDING)
  initialKzteAirdropped      Boolean            @default(false)
  initialKzteAirdropTx       String?            @db.VarChar(128)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  user                       EnergyUser         @relation(fields: [energyUserId], references: [id], onDelete: Cascade)
}

model EnergyUserSession {
  id                String      @id @default(cuid())
  energyUserId      String
  accessTokenHash   String      @unique @db.VarChar(255)
  expiresAt         DateTime
  createdAt         DateTime    @default(now())

  user              EnergyUser  @relation(fields: [energyUserId], references: [id], onDelete: Cascade)

  @@index([energyUserId])
}

model EnergyAsset {
  id                        String            @id @default(cuid())
  assetId                   String            @unique @db.VarChar(64)
  issuerEnergyUserId        String?           @db.VarChar(191)

  title                     String            @db.VarChar(255)
  description               String?           @db.Text
  location                  String?           @db.VarChar(255)
  assetType                 String            @db.VarChar(100)

  totalShares               Int
  pricePerShareKzte         Int
  investorBps               Int
  operatorBps               Int

  payoutMode                String            @db.VarChar(50)
  status                    EnergyAssetStatus @default(DRAFT)

  assetPda                  String            @unique @db.VarChar(128)
  registryPda               String            @db.VarChar(128)
  shareMintAddress          String            @unique @db.VarChar(128)
  treasuryShareAccount      String            @unique @db.VarChar(128)
  treasuryKzteAccount       String            @unique @db.VarChar(128)

  coverImageUrl             String?           @db.VarChar(512)
  documents                 EnergyAssetDocument[]
  proofBundles              EnergyAssetProofBundle[]

  proofRootHash             String            @db.VarChar(128)
  metadataUriHash           String            @db.VarChar(128)
  metadataJson              Json
  metadataCanonicalJson     String            @db.Text

  createAssetTx             String?           @db.VarChar(128)
  issueSharesTx             String?           @db.VarChar(128)

  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([issuerEnergyUserId])
  @@index([status])
}

model EnergyInvestorPosition {
  id                     String                   @id @default(cuid())
  energyUserId           String                   @db.VarChar(191)
  energyAssetId          String                   @db.VarChar(191)

  assetId                String                   @db.VarChar(64)
  assetPda               String                   @db.VarChar(128)
  shareMintAddress       String                   @db.VarChar(128)

  buyerWalletAddress     String                   @db.VarChar(128)
  buyerKzteAccount       String?                  @db.VarChar(128)
  buyerShareAccount      String                   @db.VarChar(128)

  payoutMode             EnergyPositionPayoutMode @default(KZTE)

  totalSharesPurchased   Int                      @default(0)
  totalKzteSpent         Int                      @default(0)
  averagePricePerShare   Int                      @default(0)

  lastPurchaseTx         String?                  @db.VarChar(128)
  status                 EnergyPositionStatus     @default(ACTIVE)

  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([energyUserId])
  @@index([energyAssetId])
  @@index([assetId])
  @@index([payoutMode])
  @@unique([energyUserId, energyAssetId, payoutMode], map: "energy_position_user_asset_mode_unique")
}

model EnergyRevenueEpoch {
  id                    String                   @id @default(cuid())
  energyAssetId         String                   @db.VarChar(191)

  epochIndex            Int
  revenueEpochPda       String                   @unique @db.VarChar(128)
  treasuryKzteAccount   String                   @db.VarChar(128)

  totalAmountKzte       Int
  amountPerShareKzte    Int
  totalSharesSnapshot   Int

  createEpochTx         String?                  @db.VarChar(128)
  status                EnergyRevenueEpochStatus @default(OPEN)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([energyAssetId, epochIndex])
  @@index([energyAssetId])
}

model EnergyPayoutClaim {
  id                        String                   @id @default(cuid())
  energyUserId              String                   @db.VarChar(191)
  energyAssetId             String                   @db.VarChar(191)
  energyRevenueEpochId      String                   @db.VarChar(191)

  claimReceiptPda           String                   @unique @db.VarChar(128)

  claimerWalletAddress      String                   @db.VarChar(128)
  claimerKzteAccount        String                   @db.VarChar(128)
  claimerShareAccount       String                   @db.VarChar(128)

  claimedAmountKzte         Int                      @default(0)
  claimedAmountEnergyPoints Int                      @default(0)

  payoutMode                EnergyPositionPayoutMode @default(KZTE)

  claimTx                   String?                  @db.VarChar(128)
  energyPointsMintTx        String?                  @db.VarChar(128)

  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  @@index([energyUserId])
  @@index([energyAssetId])
  @@index([energyRevenueEpochId])
  @@index([payoutMode])

  @@unique([energyUserId, energyRevenueEpochId, payoutMode], map: "energy_claim_user_epoch_mode_unique")
}

model EnergyOtcListing {
  id                    String                 @id @default(cuid())
  listingId             String                 @unique @db.VarChar(64)

  energyAssetId         String                 @db.VarChar(191)
  sellerEnergyUserId    String                 @db.VarChar(191)
  buyerEnergyUserId     String?                @db.VarChar(191)

  assetId               String                 @db.VarChar(64)
  assetPda              String                 @db.VarChar(128)
  listingPda            String                 @unique @db.VarChar(128)

  shareMintAddress      String                 @db.VarChar(128)
  sellerWalletAddress   String                 @db.VarChar(128)
  sellerShareAccount    String                 @db.VarChar(128)
  sellerKzteAccount     String                 @db.VarChar(128)
  escrowShareAccount    String                 @unique @db.VarChar(128)

  shareAmount           Int
  pricePerShareKzte     Int
  totalPriceKzte        Int
  payoutMode            EnergyPositionPayoutMode @default(KZTE)

  createListingTx       String?                @db.VarChar(128)
  fillListingTx         String?                @db.VarChar(128)
  status                EnergyOtcListingStatus @default(OPEN)

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([energyAssetId])
  @@index([sellerEnergyUserId])
  @@index([buyerEnergyUserId])
  @@index([status])
}

model EnergyUserActionPassword {
  id            String   @id @default(cuid())
  energyUserId  String   @unique @db.VarChar(191)
  passwordHash  String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([energyUserId])
}

model EnergyAssetDocument {
  id                     String                  @id @default(cuid())
  energyAssetId          String                  @db.VarChar(191)
  documentType           EnergyAssetDocumentType
  fileName               String                  @db.VarChar(255)
  mimeType               String                  @db.VarChar(128)
  storageKey             String                  @db.VarChar(512)
  fileUrl                String                  @db.VarChar(512)
  sha256Hash             String                  @db.VarChar(64)
  sizeBytes              Int
  uploadedByEnergyUserId String?                 @db.VarChar(191)
  createdAt              DateTime                @default(now())

  asset                  EnergyAsset             @relation(fields: [energyAssetId], references: [id], onDelete: Cascade)

  @@index([energyAssetId])
  @@index([documentType])
  @@index([sha256Hash])
}

model EnergyAssetProofBundle {
  id                     String      @id @default(cuid())
  energyAssetId          String      @db.VarChar(191)
  bundleVersion          Int
  proofRootHash          String      @db.VarChar(64)
  manifestJson           Json
  createdByEnergyUserId  String?     @db.VarChar(191)
  createdAt              DateTime    @default(now())

  asset                  EnergyAsset @relation(fields: [energyAssetId], references: [id], onDelete: Cascade)

  @@index([energyAssetId])
  @@unique([energyAssetId, bundleVersion], map: "energy_asset_bundle_version_unique")
}