# Порт ENERGY API
PORT=3201

# JWT secret для локальной сессии ENERGY
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
ENERGY_JWT_SECRET=REPLACE_WITH_ENERGY_JWT_SECRET

# PostgreSQL для ENERGY (schema=energy)
# Если PostgreSQL поднят локально, можно оставить как есть
DATABASE_URL="postgresql://dekyc:dekyc_password@localhost:5432/dekyc?schema=energy"

# Базовый URL DeKYC API
# Если DeKYC backend запущен локально, можно оставить как есть
DEKYC_API_BASE_URL=http://localhost:3001/api

# =========================================================
# DeKYC service credentials для сервиса ENERGY
# =========================================================
# Как получить значения:
#
# 1. Запустите DeKYC backend
# 2. Выполните команду:
#
# curl -X POST "http://localhost:3001/api/services/register" \
#   -H "Content-Type: application/json" \
#   -d "{\"name\":\"Energy\",\"description\":\"DeKYC Energy service\",\"category\":\"Marketplace\",\"requiredClaims\":[\"fullName\",\"iin\",\"birthDate\"],\"optionalClaims\":[\"email\",\"verified\",\"age18Plus\"]}"
#
# Пример ответа:
# {
#   "service": {
#     "id": "cmnnwuvyx0000bgqbdiswuyob",
#     "name": "Energy",
#     "description": "DeKYC Energy service",
#     "category": "Marketplace",
#     "clientId": "svc_xxx",
#     "status": "active",
#     "createdAt": "..."
#   },
#   "issuedCredentials": {
#     "clientId": "svc_xxx",
#     "clientSecret": "sk_xxx",
#     "responseSigningSecret": "resp_xxx"
#   }
# }
#
# После этого подставьте значения:
# - DEKYC_SERVICE_ID = service.id
# - DEKYC_CLIENT_ID = issuedCredentials.clientId
# - DEKYC_CLIENT_SECRET = issuedCredentials.clientSecret
# - DEKYC_RESPONSE_SIGNING_SECRET = issuedCredentials.responseSigningSecret

DEKYC_SERVICE_ID=REPLACE_WITH_SERVICE_ID_FROM_SERVICES_REGISTER
DEKYC_CLIENT_ID=REPLACE_WITH_CLIENT_ID_FROM_SERVICES_REGISTER
DEKYC_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET_FROM_SERVICES_REGISTER
DEKYC_RESPONSE_SIGNING_SECRET=REPLACE_WITH_RESPONSE_SIGNING_SECRET_FROM_SERVICES_REGISTER

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Путь к локальному backend signer keypair для ENERGY
# Что делать:
# - укажите путь к вашему keypair json
SOLANA_SIGNER_KEYPAIR_PATH=keys/energy-signer.json

# Символ settlement token
KZTE_SYMBOL=KZTE

# Имя settlement token
KZTE_NAME=Kazakhstan Tenge Demo

# Decimals settlement token
KZTE_DECIMALS=2

# =========================================================
# KZTE mint
# =========================================================
# Как получить KZTE_MINT_ADDRESS:
#
# 1. Убедитесь, что ENERGY API запущен
# 2. ВРЕМЕННО оставьте KZTE_MINT_ADDRESS пустым
# 3. Выполните:
#
# curl -X POST "http://localhost:3201/api/solana/kzte/init"
#
# Пример ответа:
# {
#   "mintAddress": "13J23UiPBGQ3mH12EWBDgTfzDaVo7MVGmo5Zh9dbspWr",
#   "decimals": 2,
#   "tokenProgram": "TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"
# }
#
# После этого подставьте:
# - KZTE_MINT_ADDRESS = mintAddress
#
# Если KZTE_MINT_ADDRESS уже заполнен, endpoint вернет существующий mint.
KZTE_MINT_ADDRESS=REPLACE_WITH_MINT_ADDRESS_FROM_KZTE_INIT

# Приватный ключ backend signer в формате массива чисел
# Что делать:
# - НЕ коммитить реальный ключ
# - подставить свой только локально
# - если проект реально использует эту переменную, вставьте сюда массив secret key
SOLANA_PRIVATE_KEY=[REPLACE_WITH_PRIVATE_KEY_ARRAY]

# Program ID программы tokenization_case
# Откуда брать:
# - из Anchor deploy output / Anchor.toml / IDL config после deploy
TOKENIZATION_PROGRAM_ID=REPLACE_WITH_TOKENIZATION_PROGRAM_ID

# =========================================================
# ENERGY_POINTS mint
# =========================================================
# Как получить ENERGY_POINTS_MINT_ADDRESS:
#
# 1. Убедитесь, что ENERGY API запущен
# 2. ВРЕМЕННО оставьте ENERGY_POINTS_MINT_ADDRESS пустым
# 3. Выполните:
#
# curl -X POST "http://localhost:3201/api/solana/energy-points/init"
#
# Пример ответа:
# {
#   "mintAddress": "4UTmKpdVqhx9MEGzJgm5vE78SDtQYC6apzMzZFKjVg8y",
#   "decimals": 2,
#   "tokenProgram": "TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"
# }
#
# После этого подставьте:
# - ENERGY_POINTS_MINT_ADDRESS = mintAddress
#
# Если ENERGY_POINTS_MINT_ADDRESS уже заполнен, endpoint вернет существующий mint.
ENERGY_POINTS_MINT_ADDRESS=REPLACE_WITH_MINT_ADDRESS_FROM_ENERGY_POINTS_INIT

# Decimals для ENERGY_POINTS
ENERGY_POINTS_DECIMALS=2