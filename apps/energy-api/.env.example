# ENERGY API port
PORT=3201

# JWT secret for the local ENERGY session
# What to do:
# - REQUIRED: replace with your own value
ENERGY_JWT_SECRET=REPLACE_WITH_ENERGY_JWT_SECRET

# PostgreSQL for ENERGY (schema=energy)
# If PostgreSQL is running locally, you can keep it as is
DATABASE_URL="postgresql://dekyc:dekyc_password@localhost:5432/dekyc?schema=energy"

# Base URL of the DeKYC API
# If the DeKYC backend is running locally, you can keep it as is
DEKYC_API_BASE_URL=http://localhost:3001/api

# =========================================================
# DeKYC service credentials for the ENERGY service
# =========================================================
# How to get the values:
#
# 1. Start the DeKYC backend
# 2. Run the command:
#
# curl -X POST "http://localhost:3001/api/services/register" \
#   -H "Content-Type: application/json" \
#   -d "{\"name\":\"Energy\",\"description\":\"DeKYC Energy service\",\"category\":\"Marketplace\",\"requiredClaims\":[\"fullName\",\"iin\",\"birthDate\"],\"optionalClaims\":[\"email\",\"verified\",\"age18Plus\"]}"
#
# Example response:
# {
#   "service": {
#     "id": "cmnnwuvyx0000bgqbdiswuyob",
#     "name": "Energy",
#     "description": "DeKYC Energy service",
#     "category": "Marketplace",
#     "clientId": "svc_xxx",
#     "status": "active",
#     "createdAt": "..."
#   },
#   "issuedCredentials": {
#     "clientId": "svc_xxx",
#     "clientSecret": "sk_xxx",
#     "responseSigningSecret": "resp_xxx"
#   }
# }
#
# After that, insert the values:
# - DEKYC_SERVICE_ID = service.id
# - DEKYC_CLIENT_ID = issuedCredentials.clientId
# - DEKYC_CLIENT_SECRET = issuedCredentials.clientSecret
# - DEKYC_RESPONSE_SIGNING_SECRET = issuedCredentials.responseSigningSecret

DEKYC_SERVICE_ID=REPLACE_WITH_SERVICE_ID_FROM_SERVICES_REGISTER
DEKYC_CLIENT_ID=REPLACE_WITH_CLIENT_ID_FROM_SERVICES_REGISTER
DEKYC_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET_FROM_SERVICES_REGISTER
DEKYC_RESPONSE_SIGNING_SECRET=REPLACE_WITH_RESPONSE_SIGNING_SECRET_FROM_SERVICES_REGISTER

# Redirect URI used by the Energy frontend for the DeKYC Connect callback.
# Must match redirect_uri in /connect/authorize and /connect/token.
ENERGY_DEKYC_CONNECT_REDIRECT_URI=http://localhost:3200/ru/dekyc-connect/callback

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to the local backend signer keypair for ENERGY
# What to do:
# - specify the path to your keypair json
SOLANA_SIGNER_KEYPAIR_PATH=keys/energy-signer.json

# Settlement token symbol
KZTE_SYMBOL=KZTE

# Settlement token name
KZTE_NAME=Kazakhstan Tenge Demo

# Settlement token decimals
KZTE_DECIMALS=2

# =========================================================
# KZTE mint
# =========================================================
# How to get KZTE_MINT_ADDRESS:
#
# 1. Make sure the ENERGY API is running
# 2. TEMPORARILY leave KZTE_MINT_ADDRESS empty
# 3. Run:
#
# curl -X POST "http://localhost:3201/api/solana/kzte/init"
#
# Example response:
# {
#   "mintAddress": "13J23UiPBGQ3mH12EWBDgTfzDaVo7MVGmo5Zh9dbspWr",
#   "decimals": 2,
#   "tokenProgram": "TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"
# }
#
# After that, insert:
# - KZTE_MINT_ADDRESS = mintAddress
#
# If KZTE_MINT_ADDRESS is already filled, the endpoint will return the existing mint.
KZTE_MINT_ADDRESS=REPLACE_WITH_MINT_ADDRESS_FROM_KZTE_INIT

# Backend signer private key as an array of numbers
# What to do:
# - DO NOT commit the real key
# - insert your own value only locally
# - if the project actually uses this variable, insert the secret key array here
SOLANA_PRIVATE_KEY=[REPLACE_WITH_PRIVATE_KEY_ARRAY]

# Program ID of the tokenization_case program
# Where to get it:
# - from Anchor deploy output / Anchor.toml / IDL config after deploy
TOKENIZATION_PROGRAM_ID=REPLACE_WITH_TOKENIZATION_PROGRAM_ID

# =========================================================
# ENERGY_POINTS mint
# =========================================================
# How to get ENERGY_POINTS_MINT_ADDRESS:
#
# 1. Make sure the ENERGY API is running
# 2. TEMPORARILY leave ENERGY_POINTS_MINT_ADDRESS empty
# 3. Run:
#
# curl -X POST "http://localhost:3201/api/solana/energy-points/init"
#
# Example response:
# {
#   "mintAddress": "4UTmKpdVqhx9MEGzJgm5vE78SDtQYC6apzMzZFKjVg8y",
#   "decimals": 2,
#   "tokenProgram": "TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb"
# }
#
# After that, insert:
# - ENERGY_POINTS_MINT_ADDRESS = mintAddress
#
# If ENERGY_POINTS_MINT_ADDRESS is already filled, the endpoint will return the existing mint.
ENERGY_POINTS_MINT_ADDRESS=REPLACE_WITH_MINT_ADDRESS_FROM_ENERGY_POINTS_INIT

# Decimals for ENERGY_POINTS
ENERGY_POINTS_DECIMALS=2