# Базовый URL ENERGY API
# Если energy-api запущен локально, можно оставить как есть
NEXT_PUBLIC_ENERGY_API_URL=http://localhost:3201/api

# Базовый URL DeKYC API
# Если api запущен локально, можно оставить как есть
NEXT_PUBLIC_DEKYC_API_URL=http://localhost:3001/api

# Публичный Service ID для ENERGY в DeKYC
# Откуда брать:
# - из apps/energy-api/.env
# - значение должно совпадать с DEKYC_SERVICE_ID
NEXT_PUBLIC_DEKYC_SERVICE_ID=REPLACE_WITH_VALUE_FROM_ENERGY_API_ENV_DEKYC_SERVICE_ID

# Публичный Client ID для ENERGY в DeKYC
# Откуда брать:
# - из apps/energy-api/.env
# - значение должно совпадать с DEKYC_CLIENT_ID
NEXT_PUBLIC_DEKYC_CLIENT_ID=REPLACE_WITH_VALUE_FROM_ENERGY_API_ENV_DEKYC_CLIENT_ID