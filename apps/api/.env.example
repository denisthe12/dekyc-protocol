# PostgreSQL для DeKYC (schema=public)
# Откуда брать:
# - локально можно оставить как есть, если у вас PostgreSQL запущен на localhost:5432
# - база: dekyc
# - пользователь: dekyc
# - пароль: dekyc_password
DATABASE_URL="postgresql://dekyc:dekyc_password@localhost:5432/dekyc?schema=public"

# Namespace secret для генерации псевдонимных DeKYC Connect subjectId/serviceSubjectId
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой в production
# - можно сгенерировать командой:
#   openssl rand -hex 32
DEKYC_SUBJECT_NAMESPACE_SECRET=REPLACE_WITH_SUBJECT_NAMESPACE_SECRET

# Время жизни одноразового authorization code в секундах.
# Для MVP достаточно 120 секунд.
DEKYC_CONNECT_AUTH_CODE_TTL_SECONDS=120

# Временный dev endpoint POST /api/connect/dev/authorize/complete.
# В production должен быть выключен, потому что реальный code должен выдаваться только через hosted consent UI.
DEKYC_CONNECT_DEV_COMPLETE_ENABLED=false

# Issuer URL для DeKYC Connect metadata/assertions.
# Локально можно оставить http://localhost:3001/api, потому что Nest использует global prefix /api.
DEKYC_CONNECT_ISSUER_URL=http://localhost:3001/api

# Key id для MVP HS256 assertion signer.
# Можно оставить как есть для локальной разработки.
DEKYC_CONNECT_KEY_ID=dekyc-connect-hs256-v1

# Время жизни signed identity assertion в секундах.
# Для MVP безопасно 300 секунд.
DEKYC_CONNECT_ASSERTION_TTL_SECONDS=300

# Signing secret для DeKYC Connect consent receipt и sandbox JWS/HMAC flow
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой в production
# - можно сгенерировать командой:
#   openssl rand -hex 32
DEKYC_CONNECT_SIGNING_SECRET=REPLACE_WITH_CONNECT_SIGNING_SECRET

# 64-байтный hex-ключ для шифрования чувствительных KYC-данных
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
# - можно сгенерировать командой:
#   openssl rand -hex 32
# Для примера, который использовал я: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
KYC_MASTER_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# JWT secret для DeKYC backend
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
# - можно сгенерировать любым длинным случайным значением
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# Время жизни JWT
JWT_EXPIRES_IN="7d"

# Master secret для внутренних защищенных операций DeKYC
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
MASTER_SECRET=REPLACE_WITH_MASTER_SECRET

# Solana RPC URL
# Для MVP можно оставить Devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana WebSocket URL
# Для локальной разработки можно оставить это значение,
# либо указать wss-url вашего провайдера / локального валидатора
SOLANA_WS_URL=ws://127.0.0.1:8900

# Путь к keypair Solana signer для DeKYC backend
# Что делать:
# - заменить на путь к вашему локальному keypair
# - обычно можно использовать:
#   ~/.config/solana/id.json
SOLANA_KEYPAIR_PATH=/absolute/path/to/your/solana-keypair.json

# Program ID permission_protocol
# Что делать:
# - если вы используете уже задеплоенную программу проекта на Devnet,
#   подставьте ее Program ID
# - если деплоите свою, подставьте свой Program ID после anchor deploy
SOLANA_PERMISSION_PROGRAM_ID=REPLACE_WITH_PERMISSION_PROGRAM_ID