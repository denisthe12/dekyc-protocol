# PostgreSQL for DeKYC (schema=public)
# Where to get it:
# - locally, you can keep it as is if PostgreSQL is running on localhost:5432
# - database: dekyc
# - user: dekyc
# - password: dekyc_password
DATABASE_URL="postgresql://dekyc:dekyc_password@localhost:5432/dekyc?schema=public"

# Namespace secret for generating pseudonymous DeKYC Connect subjectId/serviceSubjectId
# What to do:
# - REQUIRED: replace with your own value in production
# - you can generate it with:
#   openssl rand -hex 32
DEKYC_SUBJECT_NAMESPACE_SECRET=REPLACE_WITH_SUBJECT_NAMESPACE_SECRET

# Root secret for signing webhook payloads.
# REQUIRED: replace in production:
# openssl rand -hex 32
DEKYC_WEBHOOK_ROOT_SECRET=REPLACE_WITH_WEBHOOK_ROOT_SECRET

# Lifetime of a pending hosted authorization session in seconds.
DEKYC_CONNECT_AUTH_SESSION_TTL_SECONDS=600

# Hosted consent page URL in apps/platform.
# The route group (platform) is not included in the URL, so the local path is: /ru/connect-consent.
DEKYC_PLATFORM_CONNECT_CONSENT_URL=http://localhost:3000/ru/connect-consent

# Lifetime of a one-time authorization code in seconds.
# For the MVP, 120 seconds is enough.
DEKYC_CONNECT_AUTH_CODE_TTL_SECONDS=120

# Temporary dev endpoint POST /api/connect/dev/authorize/complete.
# In production, it must be disabled because a real code must only be issued through the hosted consent UI.
DEKYC_CONNECT_DEV_COMPLETE_ENABLED=false

# Issuer URL for DeKYC Connect metadata/assertions.
# Locally, you can keep http://localhost:3001/api because Nest uses the global prefix /api.
DEKYC_CONNECT_ISSUER_URL=http://localhost:3001/api

# Key id for the MVP HS256 assertion signer.
# You can keep it as is for local development.
DEKYC_CONNECT_KEY_ID=dekyc-connect-hs256-v1

# Lifetime of a signed identity assertion in seconds.
# For the MVP, 300 seconds is safe.
DEKYC_CONNECT_ASSERTION_TTL_SECONDS=300

# Signing secret for DeKYC Connect consent receipt and sandbox JWS/HMAC flow
# What to do:
# - REQUIRED: replace with your own value in production
# - you can generate it with:
#   openssl rand -hex 32
DEKYC_CONNECT_SIGNING_SECRET=REPLACE_WITH_CONNECT_SIGNING_SECRET

# 64-byte hex key for encrypting sensitive KYC data
# What to do:
# - REQUIRED: replace with your own value
# - you can generate it with:
#   openssl rand -hex 32
# Example value I used: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
KYC_MASTER_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# JWT secret for the DeKYC backend
# What to do:
# - REQUIRED: replace with your own value
# - you can generate it with any long random value
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# JWT lifetime
JWT_EXPIRES_IN="7d"

# Master secret for internal protected DeKYC operations
# What to do:
# - REQUIRED: replace with your own value
MASTER_SECRET=REPLACE_WITH_MASTER_SECRET

# Solana RPC URL
# For the MVP, Devnet can be kept
SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana WebSocket URL
# For local development, you can keep this value,
# or specify the wss URL of your provider / local validator
SOLANA_WS_URL=ws://127.0.0.1:8900

# Path to the Solana signer keypair for the DeKYC backend
# What to do:
# - replace with the path to your local keypair
# - usually you can use:
#   ~/.config/solana/id.json
SOLANA_KEYPAIR_PATH=/absolute/path/to/your/solana-keypair.json

# Program ID of permission_protocol
# What to do:
# - if you use the project’s already deployed program on Devnet,
#   insert its Program ID
# - if you deploy your own, insert your Program ID after anchor deploy
SOLANA_PERMISSION_PROGRAM_ID=REPLACE_WITH_PERMISSION_PROGRAM_ID