# PostgreSQL для DeKYC (schema=public)
# Откуда брать:
# - локально можно оставить как есть, если у вас PostgreSQL запущен на localhost:5432
# - база: dekyc
# - пользователь: dekyc
# - пароль: dekyc_password
DATABASE_URL="postgresql://dekyc:dekyc_password@localhost:5432/dekyc?schema=public"

# 64-байтный hex-ключ для шифрования чувствительных KYC-данных
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
# - можно сгенерировать командой:
#   openssl rand -hex 32
# Для примера, который использовал я: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
KYC_MASTER_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# JWT secret для DeKYC backend
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
# - можно сгенерировать любым длинным случайным значением
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# Время жизни JWT
JWT_EXPIRES_IN="7d"

# Master secret для внутренних защищенных операций DeKYC
# Что делать:
# - ОБЯЗАТЕЛЬНО заменить на свой
MASTER_SECRET=REPLACE_WITH_MASTER_SECRET

# Solana RPC URL
# Для MVP можно оставить Devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana WebSocket URL
# Для локальной разработки можно оставить это значение,
# либо указать wss-url вашего провайдера / локального валидатора
SOLANA_WS_URL=ws://127.0.0.1:8900

# Путь к keypair Solana signer для DeKYC backend
# Что делать:
# - заменить на путь к вашему локальному keypair
# - обычно можно использовать:
#   ~/.config/solana/id.json
SOLANA_KEYPAIR_PATH=/absolute/path/to/your/solana-keypair.json

# Program ID permission_protocol
# Что делать:
# - если вы используете уже задеплоенную программу проекта на Devnet,
#   подставьте ее Program ID
# - если деплоите свою, подставьте свой Program ID после anchor deploy
SOLANA_PERMISSION_PROGRAM_ID=REPLACE_WITH_PERMISSION_PROGRAM_ID