generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String
  emailVerified  Boolean     @default(false)

  biometricConfigured     Boolean      @default(false)
  biometricMockId         String?
  loginCodeHash           String?
  loginCodeIssuedAt       DateTime?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userCerts      UserCert[]
  kycProfiles    KycProfile[]
  permissions    Permission[]
}

model UserCert {
  id                           String    @id @default(cuid())
  userId                       String
  fullName                     String?
  firstName                    String?
  lastName                     String?
  middleName                   String?
  iin                          String?
  email                        String?
  birthDate                    String?
  gender                       String?
  birthCentury                 Int?
  certificateSerialNumber      String?
  certificateFingerprint256    String    @unique
  certificateIssuer            String?
  certificateSubject           String?
  validFrom                    String?
  validTo                      String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([iin])
}

model KycProfile {
  id                String    @id @default(cuid())
  userId            String
  fullName          String?
  firstName         String?
  lastName          String?
  middleName        String?
  iin               String?
  email             String?
  birthDate         String?
  gender            String?
  country           String?
  status            String    @default("draft")
  source            String    @default("eds_and_manual")
  profileJson       Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([iin])
}

model KycVaultEntry {
  id               String   @id @default(cuid())
  userId           String
  kycProfileId     String
  kycHash          String
  cipherText       String
  iv               String
  authTag          String
  keyVersion       String
  algorithm        String   @default("aes-256-gcm")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([kycProfileId])
  @@index([kycHash])
}

model Service {
  id                 String       @id @default(cuid())
  name               String
  clientId           String       @unique
  clientSecretHash   String
  responseSigningSecret  String?
  description        String?
  category             String?
  requiredClaims       Json?
  optionalClaims       Json?
  status             String       @default("active")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  permissions        Permission[]
  accessLogs         AccessLog[]
  permissionScopeGrants PermissionScopeGrant[]
}

model Permission {
  id                    String       @id @default(cuid())
  userId                String
  serviceId             String

  status                String
  version               Int          @default(1)

  requiredTokenAmount   Int?
  onchainPermissionPda  String?
  permissionKeyHash     String?
  kycHashSnapshot       String?
  allowedClaims         Json?
  scopesHash            String?

  mintAddress           String?
  tokenAccountAddress   String?
  tokenProgram          String?

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  revokedAt             DateTime?

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  service               Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  accessLogs            AccessLog[]
  scopeGrants           PermissionScopeGrant[]

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@unique([userId, serviceId])
}

model AccessLog {
  id            String      @id @default(cuid())
  permissionId  String
  serviceId     String

  decision      String
  reason        String?
  createdAt     DateTime    @default(now())

  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([permissionId])
  @@index([serviceId])
  @@index([createdAt])
}

model PermissionScopeGrant {
  id                  String      @id @default(cuid())
  permissionId        String
  serviceId           String

  scope               String
  requiredAmount      Int         @default(1)

  mintAddress         String?
  tokenAccountAddress String?
  tokenProgram        String?
  balanceCheckMode    String      @default("gte")

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  revokedAt           DateTime?

  permission          Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  service             Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([permissionId])
  @@index([serviceId])
  @@index([scope])
  @@unique([permissionId, scope], name: "permissionId_scope")
  
}

model ServiceRequestNonce {
  id         String   @id @default(cuid())
  serviceId  String
  nonce      String
  createdAt  DateTime @default(now())

  @@index([serviceId])
  @@unique([serviceId, nonce], name: "serviceId_nonce")
}

model DeKycSubject {
  id        String   @id @default(cuid())
  userId    String   @unique
  subjectId String   @unique
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceSubjects DeKycServiceSubject[]
  consentReceipts DeKycConsentReceipt[]
  assertions      DeKycIdentityAssertion[]

  @@index([subjectId])
}

model DeKycServiceSubject {
  id               String   @id @default(cuid())
  userId           String
  serviceId         String
  subjectId         String
  serviceSubjectId  String   @unique
  createdAt         DateTime @default(now())

  subject DeKycSubject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@index([subjectId])
  @@index([serviceSubjectId])
}

model DeKycConsentReceipt {
  id                 String   @id @default(cuid())
  consentId          String   @unique
  userId             String
  serviceId           String
  subjectId           String
  serviceSubjectId    String
  grantedClaims       Json
  consentTextVersion  String
  grantedAt           DateTime @default(now())
  expiresAt           DateTime?
  revokedAt           DateTime?
  receiptHash         String
  signature           String   @db.Text
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subject DeKycSubject @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  authorizationCodes DeKycAuthorizationCode[]
  assertions          DeKycIdentityAssertion[]

  @@index([userId])
  @@index([serviceId])
  @@index([subjectId])
  @@index([serviceSubjectId])
  @@index([status])
  @@index([consentId])
}

model DeKycAuthorizationCode {
  id           String    @id @default(cuid())
  codeHash     String    @unique
  userId       String
  serviceId     String
  redirectUri   String
  state         String?
  nonce         String?
  claimsScope   Json
  consentId     String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  consentReceipt DeKycConsentReceipt @relation(fields: [consentId], references: [consentId], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
  @@index([consentId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model DeKycIdentityAssertion {
  id                String   @id @default(cuid())
  assertionId        String   @unique
  userId             String
  serviceId           String
  subjectId           String
  serviceSubjectId    String
  consentId           String
  payloadJson         Json
  assertionJws        String   @db.Text
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime @default(now())

  subject        DeKycSubject         @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)
  consentReceipt DeKycConsentReceipt  @relation(fields: [consentId], references: [consentId], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
  @@index([subjectId])
  @@index([serviceSubjectId])
  @@index([consentId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model DeKycWebhookEndpoint {
  id          String   @id @default(cuid())
  serviceId    String
  url          String
  secretHash   String
  eventTypes   Json
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deliveries DeKycWebhookDelivery[]

  @@index([serviceId])
  @@index([status])
}

model DeKycWebhookDelivery {
  id          String    @id @default(cuid())
  endpointId  String
  eventId     String
  eventType   String
  payloadJson Json
  signature   String    @db.Text
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  endpoint DeKycWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([eventId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}