generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String
  emailVerified  Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userCerts      UserCert[]
  kycProfiles    KycProfile[]
  permissions    Permission[]
}

model UserCert {
  id                           String    @id @default(cuid())
  userId                       String
  fullName                     String?
  firstName                    String?
  lastName                     String?
  middleName                   String?
  iin                          String?
  email                        String?
  birthDate                    String?
  gender                       String?
  birthCentury                 Int?
  certificateSerialNumber      String?
  certificateFingerprint256    String    @unique
  certificateIssuer            String?
  certificateSubject           String?
  validFrom                    String?
  validTo                      String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([iin])
}

model KycProfile {
  id                String    @id @default(cuid())
  userId            String
  fullName          String?
  firstName         String?
  lastName          String?
  middleName        String?
  iin               String?
  email             String?
  birthDate         String?
  gender            String?
  country           String?
  status            String    @default("draft")
  source            String    @default("eds_and_manual")
  profileJson       Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([iin])
}

model KycVaultEntry {
  id               String   @id @default(cuid())
  userId           String
  kycProfileId     String
  kycHash          String
  cipherText       String
  iv               String
  authTag          String
  keyVersion       String
  algorithm        String   @default("aes-256-gcm")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([kycProfileId])
  @@index([kycHash])
}

model Service {
  id                 String       @id @default(cuid())
  name               String
  clientId           String       @unique
  clientSecretHash   String
  description        String?
  status             String       @default("active")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  permissions        Permission[]
  accessLogs         AccessLog[]
}

model Permission {
  id                    String       @id @default(cuid())
  userId                String
  serviceId             String

  status                String
  version               Int          @default(1)

  requiredTokenAmount   Int?
  onchainPermissionPda  String?
  permissionKeyHash     String?
  kycHashSnapshot       String?
  allowedClaims         Json?

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  revokedAt             DateTime?

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  service               Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  accessLogs            AccessLog[]

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@unique([userId, serviceId])
}

model AccessLog {
  id            String      @id @default(cuid())
  permissionId  String
  serviceId     String

  decision      String
  reason        String?
  createdAt     DateTime    @default(now())

  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([permissionId])
  @@index([serviceId])
  @@index([createdAt])
}